<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ma_hr_document_type_list" model="ir.ui.view">
        <field name="name">ma.hr.document.type.list</field>
        <field name="model">ma.hr.document.type</field>
        <field name="arch" type="xml">
            <list string="Document Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="has_expiry"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ma_hr_document_type_form" model="ir.ui.view">
        <field name="name">ma.hr.document.type.form</field>
        <field name="model">ma.hr.document.type</field>
        <field name="arch" type="xml">
            <form string="Document Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="has_expiry"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ma_hr_document_type" model="ir.actions.act_window">
        <field name="name">Document Types</field>
        <field name="res_model">ma.hr.document.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
