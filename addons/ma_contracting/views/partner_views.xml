<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend partner form with contracting financial summary -->
    <record id="view_partner_form_ma_contracting" model="ir.ui.view">
        <field name="name">res.partner.form.ma.contracting</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='ma_erp']" position="inside">
                <group string="Contracting Summary"
                       invisible="contracting_project_count == 0">
                    <group>
                        <field name="contracting_total_value" readonly="1"/>
                        <field name="contracting_total_invoiced" readonly="1"/>
                        <field name="contracting_total_received" readonly="1"/>
                    </group>
                    <group>
                        <field name="contracting_pending_balance" readonly="1"/>
                        <field name="contracting_max_overdue_days" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
