<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ma_project_payment_list" model="ir.ui.view">
        <field name="name">ma.project.payment.list</field>
        <field name="model">ma.project.payment</field>
        <field name="arch" type="xml">
            <list string="Payment Milestones"
                  decoration-danger="state == 'overdue'"
                  decoration-success="state == 'received'"
                  decoration-info="state == 'invoiced'">
                <field name="project_id"/>
                <field name="name"/>
                <field name="payment_type"/>
                <field name="amount"/>
                <field name="due_date"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'overdue'"
                       decoration-success="state == 'received'"
                       decoration-info="state == 'invoiced'"
                       decoration-muted="state == 'pending'"/>
                <field name="invoice_id" optional="show"/>
                <field name="payment_date" optional="show"/>
                <button name="action_create_invoice"
                        string="Invoice"
                        type="object"
                        class="btn-sm btn-outline-primary"
                        attrs="{'invisible': [('state', 'in', ['invoiced','received'])]}"/>
            </list>
        </field>
    </record>

    <record id="view_ma_project_payment_form" model="ir.ui.view">
        <field name="name">ma.project.payment.form</field>
        <field name="model">ma.project.payment</field>
        <field name="arch" type="xml">
            <form string="Payment Milestone">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="name"/>
                            <field name="payment_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="percentage"/>
                            <field name="amount"/>
                            <field name="due_date"/>
                            <field name="state" readonly="1"/>
                            <field name="invoice_id" readonly="1"/>
                            <field name="payment_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                    <div>
                        <button name="action_create_invoice" type="object"
                                string="Create Invoice" class="btn-primary"
                                attrs="{'invisible': [('state', 'in', ['invoiced','received'])]}"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ma_project_payment" model="ir.actions.act_window">
        <field name="name">Payment Milestones</field>
        <field name="res_model">ma.project.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('project_id.division_id.code', '=', 'contracting')]</field>
    </record>

    <!-- Overdue milestones action -->
    <record id="action_ma_project_payment_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Milestones</field>
        <field name="res_model">ma.project.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('project_id.division_id.code', '=', 'contracting'),
            ('state', '=', 'overdue')
        ]</field>
    </record>

</odoo>
