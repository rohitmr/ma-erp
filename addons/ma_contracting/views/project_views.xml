<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend project form with contracting fields -->
    <record id="view_project_form_ma_contracting" model="ir.ui.view">
        <field name="name">project.project.form.ma.contracting</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <!-- Smart button for payment milestones -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="action_view_payment_milestones"
                        icon="fa-calendar-check-o"
                        attrs="{'invisible': [('division_id.code', '!=', 'contracting')]}">
                    <field name="payment_count" widget="statinfo" string="Milestones"/>
                </button>
            </xpath>

            <!-- Contracting details after description -->
            <xpath expr="//field[@name='description']" position="after">
                <group string="Contracting Details"
                       attrs="{'invisible': [('division_id.code', '!=', 'contracting')]}">
                    <group>
                        <field name="project_type_id"/>
                        <field name="client_po_number"/>
                        <field name="client_npo_number"/>
                    </group>
                    <group>
                        <field name="contract_value"/>
                        <field name="currency_id" groups="base.group_multi_currency"/>
                        <field name="retention_percentage"/>
                        <field name="retention_amount" readonly="1"/>
                    </group>
                </group>

                <!-- Financial summary -->
                <group string="Financial Summary"
                       attrs="{'invisible': [('division_id.code', '!=', 'contracting')]}">
                    <group>
                        <field name="total_invoiced" readonly="1"/>
                        <field name="total_received" readonly="1"/>
                        <field name="pending_balance" readonly="1"/>
                    </group>
                    <group>
                        <field name="profitability_amount" readonly="1"/>
                        <field name="profitability_percentage" readonly="1"/>
                        <field name="overdue_days" readonly="1"/>
                    </group>
                </group>

                <!-- Payment milestones inline tab -->
                <notebook attrs="{'invisible': [('division_id.code', '!=', 'contracting')]}">
                    <page string="Payment Milestones" name="payment_milestones">
                        <field name="payment_ids">
                            <list editable="bottom"
                                  decoration-danger="state == 'overdue'"
                                  decoration-success="state == 'received'"
                                  decoration-info="state == 'invoiced'">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="payment_type"/>
                                <field name="percentage"/>
                                <field name="amount"/>
                                <field name="due_date"/>
                                <field name="state" widget="badge"
                                       decoration-danger="state == 'overdue'"
                                       decoration-success="state == 'received'"
                                       decoration-info="state == 'invoiced'"
                                       decoration-muted="state == 'pending'"/>
                                <field name="invoice_id" optional="show"/>
                                <field name="payment_date" optional="show"/>
                                <button name="action_create_invoice"
                                        string="Create Invoice"
                                        type="object"
                                        class="btn-sm btn-outline-primary"
                                        attrs="{'invisible': [('state', 'in', ['invoiced','received'])]}"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>

            <field name="division_id" invisible="1"/>

        </field>
    </record>

    <!-- Action: contracting projects -->
    <record id="action_contracting_projects" model="ir.actions.act_window">
        <field name="name">Contracting Projects</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('division_id.code', '=', 'contracting')]</field>
        <field name="context">{'default_division_id': False}</field>
    </record>

</odoo>
