<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ma_project_type_list" model="ir.ui.view">
        <field name="name">ma.project.type.list</field>
        <field name="model">ma.project.type</field>
        <field name="arch" type="xml">
            <list string="Project Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ma_project_type_form" model="ir.ui.view">
        <field name="name">ma.project.type.form</field>
        <field name="model">ma.project.type</field>
        <field name="arch" type="xml">
            <form string="Project Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ma_project_type" model="ir.actions.act_window">
        <field name="name">Project Types</field>
        <field name="res_model">ma.project.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
