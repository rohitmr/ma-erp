<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_service_jobs" model="ir.actions.report">
        <field name="name">Service Job Report</field>
        <field name="model">project.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ma_service.report_service_job_document</field>
        <field name="report_file">ma_service.report_service_job_document</field>
        <field name="binding_model_id" ref="project.model_project_task"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_service_job_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Service Job — <span t-field="doc.job_sequence"/></h2>
                        <hr/>
                        <div class="row mt-3">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-bold">Client</td>
                                        <td><span t-field="doc.partner_id"/></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Service Type</td>
                                        <td><span t-field="doc.service_type_id"/></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Government Reference</td>
                                        <td><span t-field="doc.govt_reference"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="fw-bold">Assigned To</td>
                                        <td>
                                            <t t-foreach="doc.user_ids" t-as="u">
                                                <span t-esc="u.name"/>
                                                <t t-if="not u_last">, </t>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Due Date</td>
                                        <td><span t-field="doc.date_deadline"/></td>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Status</td>
                                        <td><span t-field="doc.stage_id"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <t t-if="doc.description">
                            <h4 class="mt-3">Description</h4>
                            <div t-field="doc.description"/>
                        </t>

                        <t t-if="doc.client_notes">
                            <h4 class="mt-3">Client Notes</h4>
                            <p t-field="doc.client_notes"/>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
