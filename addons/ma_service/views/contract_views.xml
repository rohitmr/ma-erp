<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_service_contract_list" model="ir.ui.view">
        <field name="name">ma.service.contract.list</field>
        <field name="model">ma.service.contract</field>
        <field name="arch" type="xml">
            <list string="PRO Contracts"
                  decoration-warning="state == 'draft'"
                  decoration-success="state == 'active'"
                  decoration-muted="state in ('expired','cancelled')">
                <field name="name"/>
                <field name="client_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="monthly_fee"/>
                <field name="billing_day"/>
                <field name="invoice_count" string="Invoices"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'draft'"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_service_contract_form" model="ir.ui.view">
        <field name="name">ma.service.contract.form</field>
        <field name="model">ma.service.contract</field>
        <field name="arch" type="xml">
            <form string="PRO Contract">
                <header>
                    <button name="action_activate" string="Activate"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            attrs="{'invisible': [('state', 'not in', ['draft','active'])]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_invoices" icon="fa-file-text-o">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Contract Details">
                            <field name="client_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Billing">
                            <field name="monthly_fee"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="billing_day"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Services Included" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="service_type_id"/>
                                    <field name="description"/>
                                    <field name="quantity_per_month"/>
                                </list>
                            </field>
                        </page>
                        <page string="Internal Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_service_contract" model="ir.actions.act_window">
        <field name="name">PRO Contracts</field>
        <field name="res_model">ma.service.contract</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
