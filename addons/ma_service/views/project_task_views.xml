<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend task form to add service fields -->
    <record id="view_task_form_ma_service" model="ir.ui.view">
        <field name="name">project.task.form.ma.service</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <!-- Job number below task name -->
            <xpath expr="//field[@name='name']" position="before">
                <field name="job_sequence" readonly="1"
                       invisible="not is_service_job"/>
            </xpath>

            <!-- Service fields after description -->
            <xpath expr="//field[@name='description']" position="after">
                <group string="Service Details"
                       invisible="not is_service_job">
                    <group>
                        <field name="service_type_id"/>
                        <field name="govt_reference"/>
                    </group>
                    <group>
                        <field name="is_overdue" readonly="1"/>
                    </group>
                    <group string="Client Notes" colspan="2">
                        <field name="client_notes" nolabel="1"
                               placeholder="Notes visible to the client on the portal..."/>
                    </group>
                </group>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <field name="is_service_job" invisible="1"/>
            </xpath>

        </field>
    </record>

    <!-- Service job list view -->
    <record id="view_task_list_ma_service" model="ir.ui.view">
        <field name="name">project.task.list.ma.service</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <list string="Service Jobs" decoration-danger="is_overdue == True">
                <field name="job_sequence" optional="show"/>
                <field name="name"/>
                <field name="service_type_id" optional="show"/>
                <field name="partner_id" string="Client"/>
                <field name="user_ids" widget="many2many_avatar_user" string="Assigned To"/>
                <field name="date_deadline"/>
                <field name="stage_id"/>
                <field name="is_overdue" optional="show"/>
                <field name="govt_reference" optional="hide"/>
                <field name="priority" widget="priority" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Action: all service jobs -->
    <record id="action_service_job_all" model="ir.actions.act_window">
        <field name="name">Service Jobs</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="domain">[('is_service_job', '=', True)]</field>
        <field name="context">{'default_is_service_job': True}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_task_list_ma_service')}),
        ]"/>
    </record>

    <!-- Action: overdue jobs -->
    <record id="action_service_job_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Jobs</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_service_job', '=', True), ('is_overdue', '=', True)]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_task_list_ma_service')}),
        ]"/>
    </record>

</odoo>
