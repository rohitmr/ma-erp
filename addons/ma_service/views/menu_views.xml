              parent="ma_base.menu_ma_erp_root"
              sequence="10"
              groups="ma_base.group_ma_service_user"/>

    <menuitem id="menu_ma_service_jobs"
              name="Jobs"
              parent="menu_ma_service_root"
              action="action_service_job_all"
