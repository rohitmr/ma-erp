<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ma_base.MaDashboard">
        <div class="o_action o_view_controller ma_dashboard">
            <div class="o_content">
                <div class="container-fluid p-4">

                    <!-- Header -->
                    <div class="row mb-4 align-items-center">
                        <div class="col">
                            <h2 class="ma_dashboard_title">MA ERP — Dashboard</h2>
                        </div>
                        <div class="col-auto text-muted small">
                            <t t-esc="state.today"/>
                        </div>
                    </div>

                    <!-- Loading spinner -->
                    <t t-if="state.loading">
                        <div class="d-flex justify-content-center align-items-center" style="height:200px">
                            <div class="spinner-border text-primary" role="status"/>
                        </div>
                    </t>

                    <t t-else="">
                        <!-- ===== Row 1: Financial KPIs ===== -->
                        <div class="row g-3 mb-4">
                            <div class="col-xl-3 col-md-6">
                                <div class="card h-100 border-0 shadow-sm ma_kpi_card ma_kpi_primary"
                                     t-on-click="() => this.openAction('account.action_account_receivable')">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fa fa-money fa-2x me-3 text-primary"/>
                                            <div>
                                                <div class="text-muted small">Total Receivables</div>
                                                <div class="fw-bold fs-4 text-primary">
                                                    <t t-esc="state.total_receivables_formatted"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-md-6">
                                <div class="card h-100 border-0 shadow-sm ma_kpi_card ma_kpi_danger"
                                     t-on-click="() => this.openOverdue()">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fa fa-exclamation-circle fa-2x me-3 text-danger"/>
                                            <div>
                                                <div class="text-muted small">Overdue Amount</div>
                                                <div class="fw-bold fs-4 text-danger">
                                                    <t t-esc="state.overdue_amount_formatted"/>
                                                </div>
                                                <div class="text-muted small">
                                                    <t t-esc="state.overdue_count"/> invoice(s)
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-md-6">
                                <div class="card h-100 border-0 shadow-sm ma_kpi_card ma_kpi_warning"
                                     t-on-click="() => this.openPendingJobs()">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fa fa-tasks fa-2x me-3 text-warning"/>
                                            <div>
                                                <div class="text-muted small">Pending Service Jobs</div>
                                                <div class="fw-bold fs-4 text-warning">
                                                    <t t-esc="state.pending_jobs"/>
                                                </div>
                                                <div class="text-danger small">
                                                    <t t-esc="state.overdue_jobs"/> overdue
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-md-6">
                                <div class="card h-100 border-0 shadow-sm ma_kpi_card ma_kpi_success"
                                     t-on-click="() => this.openProjects()">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center mb-2">
                                            <i class="fa fa-building fa-2x me-3 text-success"/>
                                            <div>
                                                <div class="text-muted small">Ongoing Projects</div>
                                                <div class="fw-bold fs-4 text-success">
                                                    <t t-esc="state.ongoing_projects"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== Row 2: Division Quick Links ===== -->
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <h5 class="text-muted mb-3">Quick Access</h5>
                            </div>

                            <!-- Service Division -->
                            <div class="col-xl-4 col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-primary text-white fw-bold">
                                        <i class="fa fa-briefcase me-2"/>Service Division
                                    </div>
                                    <div class="card-body d-flex flex-column gap-2">
                                        <button class="btn btn-outline-primary btn-sm text-start"
                                                t-on-click="() => this.openAction('ma_service.action_service_job_all')">
                                            <i class="fa fa-list me-2"/>All Jobs
                                        </button>
                                        <button class="btn btn-outline-warning btn-sm text-start"
                                                t-on-click="() => this.openPendingJobs()">
                                            <i class="fa fa-clock-o me-2"/>Pending Jobs
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('ma_service.action_service_contract')">
                                            <i class="fa fa-file-text me-2"/>PRO Contracts
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Contracting Division -->
                            <div class="col-xl-4 col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-success text-white fw-bold">
                                        <i class="fa fa-building me-2"/>Contracting Division
                                    </div>
                                    <div class="card-body d-flex flex-column gap-2">
                                        <button class="btn btn-outline-success btn-sm text-start"
                                                t-on-click="() => this.openProjects()">
                                            <i class="fa fa-folder-open me-2"/>All Projects
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('ma_contracting.action_ma_project_payment')">
                                            <i class="fa fa-calendar me-2"/>Payment Milestones
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('sale.action_quotations_with_onboarding')">
                                            <i class="fa fa-file me-2"/>Quotations (BOQ)
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Trading Division -->
                            <div class="col-xl-4 col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-header bg-warning text-dark fw-bold">
                                        <i class="fa fa-shopping-cart me-2"/>Trading Division
                                    </div>
                                    <div class="card-body d-flex flex-column gap-2">
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('sale.action_quotations_with_onboarding')">
                                            <i class="fa fa-shopping-bag me-2"/>Sales Orders
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('purchase.purchase_rfq')">
                                            <i class="fa fa-truck me-2"/>Purchase Orders
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm text-start"
                                                t-on-click="() => this.openAction('stock.action_stock_inventory')">
                                            <i class="fa fa-cubes me-2"/>Inventory
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== Row 3: HR Alert ===== -->
                        <t t-if="state.expiring_docs > 0">
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="alert alert-warning d-flex align-items-center" role="alert"
                                         style="cursor:pointer" t-on-click="() => this.openAction('ma_hr_ext.action_ma_hr_document_expiring')">
                                        <i class="fa fa-id-card fa-lg me-3"/>
                                        <div>
                                            <strong><t t-esc="state.expiring_docs"/> employee document(s)</strong>
                                            expiring within the next 30 days.
                                            <span class="ms-2 text-decoration-underline">View now →</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>

                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
